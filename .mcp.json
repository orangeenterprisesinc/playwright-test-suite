{
  "inputs": [
    {
      "id": "jira-url",
      "type": "promptString",
      "description": "Jira base URL (e.g. https://yourcompany.atlassian.net)"
    },
    {
      "id": "jira-username",
      "type": "promptString",
      "description": "Jira username/email"
    },
    {
      "id": "jira-api-token",
      "type": "promptString",
      "description": "Jira API token",
      "password": true
    }
  ],
  "mcpServers": {
    "playwright-test": {
      "command": "node",
      "args": [
        "node_modules/@playwright/test/cli.js",
        "run-test-mcp-server"
      ]
    },
    "jira": {
      "command": "uvx",
      "args": [
        "mcp-atlassian"
      ],
      "env": {
        "JIRA_URL": "${input:jira-url}",
        "JIRA_USERNAME": "${input:jira-username}",
        "JIRA_API_TOKEN": "${input:jira-api-token}"
      }
    }
  }
}
