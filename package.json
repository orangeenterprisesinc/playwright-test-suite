{
  "name": "playwright-pom-core",
  "version": "1.0.0",
  "description": "Playwright + TypeScript POM test framework for PET Tiger",
  "scripts": {
    "test": "node scripts/run-playwright.js local",
    "test:dev": "node scripts/run-playwright.js dev",
    "test:qa": "node scripts/run-playwright.js qa",
    "test:headed": "node scripts/run-playwright.js local --project=chromium --headed",
    "test:ui": "node scripts/run-playwright.js local --ui",
    "test:debug": "node scripts/run-playwright.js local --project=chromium --debug",
    "test:smoke": "node scripts/run-playwright.js local --grep=@Smoke",
    "test:last-failed": "node scripts/run-playwright.js local --last-failed",
    "docker:build": "docker build -t playwright-test-suite .",
    "docker:run": "docker run --rm -e BASE_URL -e API_URL -e USER_NAME -e PASSWORD -e TEST_ENV -v \"%cd%/test-results:/app/test-results\" -v \"%cd%/playwright-report:/app/playwright-report\" playwright-test-suite",
    "test:report": "node node_modules/@playwright/test/cli.js show-report",
    "report:allure": "node scripts/generate-allure-report.js",
    "report:allure:open": "node scripts/open-allure-report.js",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@playwright/mcp": "^0.0.53",
    "@playwright/test": "1.58.2",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^8.0.1",
    "@types/papaparse": "^5.5.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "allure-commandline": "^2.43.0",
    "allure-js-commons": "^3.10.2",
    "allure-playwright": "^3.10.2",
    "dotenv": "^17.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemailer": "^9.0.3",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0"
  }
}
