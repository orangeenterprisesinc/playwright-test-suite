{
  "name": "playwright-pom-core",
  "version": "1.0.0",
  "description": "Playwright + TypeScript POM test framework for PET Tiger",
  "scripts": {
    "test": "cross-env TEST_ENV=local playwright test",
    "test:dev": "cross-env TEST_ENV=dev playwright test",
    "test:qa": "cross-env TEST_ENV=qa playwright test",
    "test:headed": "cross-env TEST_ENV=local playwright test --project=chromium --headed",
    "test:ui": "cross-env TEST_ENV=local playwright test --ui",
    "test:debug": "cross-env TEST_ENV=local playwright test --project=chromium --debug",
    "test:smoke": "cross-env TEST_ENV=local playwright test --grep=@Smoke",
    "test:last-failed": "cross-env TEST_ENV=local playwright test --last-failed",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@playwright/mcp": "^0.0.53",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.2",
    "@types/papaparse": "^5.5.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-prettier": "^5.5.5",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.1",
    "typescript": "^5.3.0"
  }
}
