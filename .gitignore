.env

# Reporting output
allure-results/
allure-report/
logs/

# Claude Code — the shared .claude/ folder IS committed; only personal
# local overrides are ignored.
.claude/settings.local.json

#Testing context
Testing video/

# NOTE: package-lock.json is intentionally tracked — CI uses `npm ci`,
# which requires it.


# Local SQL Server backup (12.9GB real client data — never commit)
db backup/
*.bak
docker-e2e/.env
