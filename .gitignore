# Dependencies
node_modules/

# Playwright output
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Auth storage state (contains session cookies — never commit)
/playwright/.auth/
.auth/

# Personal env overrides (SMTP credentials etc.) — loaded by envLoader as the
