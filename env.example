# Template for env.<name> files (env.local / env.dev / env.qa).
# Copy to env.<name> and fill in the values for that environment.
# Select at runtime with TEST_ENV=<name> (defaults to 'local').
#
# Precedence (src/config/envLoader.ts):
#   1. OS/CI environment variables (never overridden — CI secrets win)
#   2. env.<name> file
#   3. .env file (optional shared base)

# Application under test
BASE_URL=http://localhost:3000
API_URL=http://localhost:8080/api

# Application login credentials — real secrets belong in CI secret stores
# or your local shell, NOT in committed env files.
USER_NAME=CHANGE_ME
PASSWORD=CHANGE_ME

# Test data source: 'json' | 'csv' (read directly, no conversion)
TEST_DATA_SOURCE=json

# Optional: override retry count (defaults: CI=2, local=0)
# RETRY=1

# Optional: email a run summary after each execution (off by default).
# Real SMTP credentials belong in CI secrets or your local shell.
# SEND_EMAIL=yes
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=CHANGE_ME
# SMTP_PASSWORD=CHANGE_ME
# EMAIL_FROM=qa-bot@example.com
# EMAIL_TO=team@example.com,lead@example.com
# Max size (MB) per report zip attached to the email; oversized ones are
# dropped in favor of the CI run link. Defaults to 20 (safely under Gmail's
# ~25MB attachment cap after base64 overhead).
# EMAIL_MAX_ATTACHMENT_MB=20

# Optional: post a run summary to Slack after each execution (off by default).
# SLACK_WEBHOOK_URL is a secret (Slack Incoming Webhook) — never commit the
# real value; keep it in CI secrets or your local shell.
# SEND_SLACK=yes
# SLACK_WEBHOOK_URL=CHANGE_ME

# Optional: "owner" label shown on every test in the Allure report (default: QA).
# ALLURE_OWNER=QA

# Optional: push a run summary to an ELK/Elasticsearch ingest endpoint (off by default).
# SEND_RESULT_ELK=yes
# ELK_URL=CHANGE_ME

# Optional: API request authentication — only relevant to apiRequest/api.fixture
# calls, independent of the Keycloak browser login above. Defaults to 'none'.
# AUTH_TYPE=oauth2               # oauth2 | basic | apikey | none
# ACCESS_TOKEN_URL=CHANGE_ME
# CLIENT_ID=CHANGE_ME
# CLIENT_SECRET=CHANGE_ME
# AUTH_USERNAME=CHANGE_ME
# AUTH_PASSWORD=CHANGE_ME
# API_KEY=CHANGE_ME
# API_KEY_HEADER=X-API-Key

# ── Test-user cleanup via SQL (optional) ────────────────────────────────────
# The PET Tiger UI has no delete-user action and soft-deletes (Deleted=1), so
# tests that create users clean them up directly in SQL Server. Requires the
# run host to reach the DB (local / self-hosted CI). Leave DB_CLEANUP=no where
# there is no SQL access — cleanup then skips with a warning.
DB_CLEANUP=no                    # yes | no
DB_SERVER=localhost,1433         # host[,port] or host\INSTANCE
DB_CLIENT=CHANGE_ME              # client/tenant database holding app Users
DB_MASTER=CHANGE_ME              # master database holding global Users rows
DB_TRUSTED=yes                   # yes = Windows integrated auth (sqlcmd -E)
# DB_USER=CHANGE_ME              # only when DB_TRUSTED=no
# DB_PASSWORD=CHANGE_ME          # only when DB_TRUSTED=no
# SQLCMD_PATH=sqlcmd             # override if sqlcmd is not on PATH
